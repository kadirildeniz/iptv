{
  "expo": {
    "name": "Setbox",
    "slug": "setbox",
    "version": "1.0.6",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "setbox",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.basecodestudio.setbox"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/tv_icon.png",
        "backgroundColor": "#0033ab"
      },
      "package": "com.basecodestudio.setbox",
      "versionCode": 17,
      "useNextNotificationsApi": true,
      "softwareKeyboardLayoutMode": "pan",
      "isTV": true,
      "tvBanner": "./assets/images/tv_banner.png",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashscreen_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0033ab"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "@morrowdigital/watermelondb-expo-plugin",
        {
          "useSQLite": true,
          "disableJsi": true,
          "enableHermes": true
        }
      ],
      "expo-sqlite",
      "react-native-video",
      "./plugins/withAudioBooster",
      [
        "./plugins/withAndroidTVFeatures",
        {
          "tvBanner": "./assets/images/tv_banner.png"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "2.0.21",
            "extraProguardRules": "-keep class com.facebook.react.** { *; } -keep class com.nozbe.watermelondb.** { *; } -keep class com.swmansion.reanimated.** { *; }",
            "newArchEnabled": true
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1d0953d-3ab6-4e07-b892-8004445f2dda"
      }
    }
  }
}